generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

enum MovementType {
  INBOUND
  OUTBOUND
  TRANSFER
  ADJUSTMENT
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  IMPORT_ERROR
  SYSTEM
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

enum ImportType {
  PRODUCTS
  INITIAL_STOCK
  MOVEMENTS
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(VIEWER)
  isActive         Boolean   @default(true) @map("is_active")
  refreshTokenHash String?   @map("refresh_token_hash")
  lastLoginAt      DateTime? @map("last_login_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  stockMovements StockMovement[]
  importJobs     ImportJob[]

  @@map("users")
}

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  sku       String   @unique
  name      String
  category  String
  costPrice Decimal  @map("cost_price") @db.Decimal(10, 2)
  minStock  Decimal  @default(0) @map("min_stock") @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stockMovements StockMovement[]
  stocks         Stock[]
  alerts         Alert[]

  @@map("products")
}

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  location  String
  manager   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stockMovements StockMovement[]
  stocks         Stock[]
  alerts         Alert[]

  @@map("warehouses")
}

model StockMovement {
  id                 String       @id @default(uuid()) @db.Uuid
  productId          String       @map("product_id") @db.Uuid
  warehouseId        String       @map("warehouse_id") @db.Uuid
  type               MovementType
  quantity           Decimal      @db.Decimal(10, 2)
  reference          String
  notes              String?
  transactionId      String?      @map("transaction_id") @db.Uuid
  createdById        String       @map("created_by_id") @db.Uuid
  correctsMovementId String?      @map("corrects_movement_id") @db.Uuid
  createdAt          DateTime     @default(now()) @map("created_at")

  product          Product         @relation(fields: [productId], references: [id])
  warehouse        Warehouse       @relation(fields: [warehouseId], references: [id])
  createdBy        User            @relation(fields: [createdById], references: [id])
  correctsMovement StockMovement?  @relation("MovementCorrection", fields: [correctsMovementId], references: [id])
  correctedBy      StockMovement[] @relation("MovementCorrection")

  @@index([productId])
  @@index([warehouseId])
  @@index([type])
  @@index([transactionId])
  @@index([createdById])
  @@index([createdAt(sort: Desc)])
  @@index([productId, warehouseId, createdAt(sort: Desc)])
  @@map("stock_movements")
}

model Stock {
  productId   String   @map("product_id") @db.Uuid
  warehouseId String   @map("warehouse_id") @db.Uuid
  quantity    Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@id([productId, warehouseId])
  @@index([warehouseId])
  @@index([productId])
  @@map("stocks")
}

model PurchaseOrder {
  id               String   @id @default(uuid()) @db.Uuid
  supplierName     String?  @map("supplier_name")
  status           String   @default("draft")
  quantityOrdered  Decimal? @map("quantity_ordered") @db.Decimal(10, 2)
  quantityReceived Decimal? @map("quantity_received") @db.Decimal(10, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("purchase_orders")
}

model ImportJob {
  id          String     @id @default(uuid()) @db.Uuid
  type        ImportType
  status      JobStatus  @default(PENDING)
  createdById String     @map("created_by_id") @db.Uuid
  errorLog    Json?      @map("error_log")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  createdBy User @relation(fields: [createdById], references: [id])

  @@map("import_jobs")
}

model Alert {
  id          String      @id @default(uuid()) @db.Uuid
  productId   String      @map("product_id") @db.Uuid
  warehouseId String      @map("warehouse_id") @db.Uuid
  type        AlertType
  status      AlertStatus @default(ACTIVE)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("alerts")
}
