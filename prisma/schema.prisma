generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

enum MovementType {
  INBOUND
  OUTBOUND
  TRANSFER
  ADJUSTMENT
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  IMPORT_ERROR
  SYSTEM
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

enum ImportType {
  PRODUCTS
  INITIAL_STOCK
  MOVEMENTS
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

model User {
  id               String    @id @default(uuid()) @db.Uuid
  email            String    @unique
  name             String    @default("Operador")
  passwordHash     String    @map("password_hash")
  role             UserRole  @default(VIEWER)
  isActive         Boolean   @default(true) @map("is_active")
  refreshTokenHash String?   @map("refresh_token_hash")
  lastLoginAt      DateTime? @map("last_login_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  stockMovements StockMovement[]
  importJobs     ImportJob[]
  resolvedAlerts Alert[]
  physicalInventorySessions PhysicalInventorySession[]
  webhookSubscriptions WebhookSubscription[]

  @@map("users")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  sku       String   @unique
  name      String
  category  String
  costPrice Decimal  @map("cost_price") @db.Decimal(10, 2)
  minStock  Decimal  @default(0) @map("min_stock") @db.Decimal(10, 2)
  isActive         Boolean  @default(true) @map("is_active")
  hasSerialNumbers Boolean  @default(false) @map("has_serial_numbers")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stockMovements StockMovement[]
  stocks         Stock[]
  alerts         Alert[]
  batches        Batch[]
  serialNumbers  SerialNumber[]
  purchaseOrderItems PurchaseOrderItem[]

  @@map("products")
}

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  code      String   @unique @default(uuid())
  location  String
  manager   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stockMovements StockMovement[]
  stocks         Stock[]
  alerts         Alert[]
  batchStocks    BatchStock[]
  serialNumbers  SerialNumber[]
  physicalInventorySessions PhysicalInventorySession[]
  purchaseOrders PurchaseOrder[]

  @@map("warehouses")
}

model StockMovement {
  id                 String       @id @default(uuid()) @db.Uuid
  productId          String       @map("product_id") @db.Uuid
  warehouseId        String       @map("warehouse_id") @db.Uuid
  type               MovementType
  quantity           Decimal      @db.Decimal(10, 2)
  reference          String
  notes              String?
  transactionId      String?      @map("transaction_id") @db.Uuid
  createdById        String       @map("created_by_id") @db.Uuid
  correctsMovementId String?      @map("corrects_movement_id") @db.Uuid
  batchId            String?      @map("batch_id") @db.Uuid
  physicalInventorySessionId String? @map("physical_inventory_session_id") @db.Uuid
  createdAt          DateTime     @default(now()) @map("created_at")

  product          Product         @relation(fields: [productId], references: [id])
  warehouse        Warehouse       @relation(fields: [warehouseId], references: [id])
  createdBy        User            @relation(fields: [createdById], references: [id])
  correctsMovement StockMovement?  @relation("MovementCorrection", fields: [correctsMovementId], references: [id])
  correctedBy      StockMovement[] @relation("MovementCorrection")
  batch            Batch?          @relation(fields: [batchId], references: [id])
  physicalInventorySession PhysicalInventorySession? @relation(fields: [physicalInventorySessionId], references: [id])

  @@index([productId])
  @@index([warehouseId])
  @@index([type])
  @@index([transactionId])
  @@index([createdById])
  @@index([physicalInventorySessionId])
  @@index([batchId])
  @@index([createdAt(sort: Desc)])
  @@index([productId, warehouseId, createdAt(sort: Desc)])
  @@map("stock_movements")
}

model Stock {
  productId   String   @map("product_id") @db.Uuid
  warehouseId String   @map("warehouse_id") @db.Uuid
  quantity    Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@id([productId, warehouseId])
  @@index([warehouseId])
  @@index([productId])
  @@map("stocks")
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id          String              @id @default(uuid()) @db.Uuid
  supplierId  String              @map("supplier_id") @db.Uuid
  warehouseId String              @map("warehouse_id") @db.Uuid
  status      PurchaseOrderStatus @default(DRAFT)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  items     PurchaseOrderItem[]

  @@index([supplierId])
  @@index([warehouseId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String   @id @default(uuid()) @db.Uuid
  purchaseOrderId  String   @map("purchase_order_id") @db.Uuid
  productId        String   @map("product_id") @db.Uuid
  quantityOrdered  Int      @map("quantity_ordered")
  quantityReceived Int      @default(0) @map("quantity_received")
  costPrice        Decimal  @map("cost_price") @db.Decimal(10, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

model ImportJob {
  id          String     @id @default(uuid()) @db.Uuid
  type        ImportType
  status      JobStatus  @default(PENDING)
  createdById String     @map("created_by_id") @db.Uuid
  errorLog    Json?      @map("error_log")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  createdBy User @relation(fields: [createdById], references: [id])

  @@map("import_jobs")
}

model Alert {
  id           String      @id @default(uuid()) @db.Uuid
  productId    String      @map("product_id") @db.Uuid
  warehouseId  String      @map("warehouse_id") @db.Uuid
  type         AlertType
  status       AlertStatus @default(ACTIVE)
  message      String
  resolvedAt   DateTime?   @map("resolved_at")
  resolvedById String?     @map("resolved_by_id") @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  product    Product   @relation(fields: [productId], references: [id])
  warehouse  Warehouse @relation(fields: [warehouseId], references: [id])
  resolvedBy User?     @relation(fields: [resolvedById], references: [id])

  @@map("alerts")
}

model Batch {
  id                String    @id @default(uuid()) @db.Uuid
  batchNumber       String    @map("batch_number")
  productId         String    @map("product_id") @db.Uuid
  supplierId        String?   @map("supplier_id")
  expiryDate        DateTime? @map("expiry_date") @db.Date
  manufacturingDate DateTime? @map("manufacturing_date") @db.Date
  initialQuantity   Decimal   @map("initial_quantity") @db.Decimal(12, 4)
  notes             String?
  createdById       String    @map("created_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at")

  product           Product   @relation(fields: [productId], references: [id])
  movements         StockMovement[]
  batchStocks       BatchStock[]
  serialNumbers     SerialNumber[]

  @@unique([productId, batchNumber])
  @@index([productId])
  @@index([expiryDate])
  @@map("batches")
}

model BatchStock {
  batchId     String   @map("batch_id") @db.Uuid
  warehouseId String   @map("warehouse_id") @db.Uuid
  quantity    Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  batch     Batch     @relation(fields: [batchId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@id([batchId, warehouseId])
  @@index([warehouseId])
  @@index([batchId])
  @@map("batch_stocks")
}

enum SerialNumberStatus {
  available
  reserved
  consumed
}

model SerialNumber {
  id                 String             @id @default(uuid()) @db.Uuid
  serialNumber       String             @map("serial_number")
  productId          String             @map("product_id") @db.Uuid
  batchId            String?            @map("batch_id") @db.Uuid
  warehouseId        String?            @map("warehouse_id") @db.Uuid
  status             SerialNumberStatus @default(available)
  inboundMovementId  String?            @map("inbound_movement_id") @db.Uuid
  outboundMovementId String?            @map("outbound_movement_id") @db.Uuid
  notes              String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  product            Product       @relation(fields: [productId], references: [id])
  batch              Batch?        @relation(fields: [batchId], references: [id])
  warehouse          Warehouse?    @relation(fields: [warehouseId], references: [id])
  
  // No hay relacion explicita definida bidireccional en StockMovement como pidió el usuario para evitar tocar el core demasiado,
  // solo mantenemos los foreign keys de movimiento para la trazabilidad

  @@unique([productId, serialNumber])
  @@index([productId, status])
  @@index([warehouseId, status])
  @@index([batchId])
  @@map("serial_numbers")
}

enum PhysicalInventoryStatus {
  processing
  completed
  completed_with_differences
  completed_with_errors
  failed
}

model PhysicalInventorySession {
  id            String                  @id @default(uuid()) @db.Uuid
  warehouseId   String                  @map("warehouse_id") @db.Uuid
  status        PhysicalInventoryStatus @default(processing)
  matchedItems  Int                     @default(0) @map("matched_items")
  adjustedItems Int                     @default(0) @map("adjusted_items")
  skippedItems  Int                     @default(0) @map("skipped_items")
  errorLog      Json?                   @map("error_log")
  createdById   String                  @map("created_by_id") @db.Uuid
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")

  warehouse Warehouse       @relation(fields: [warehouseId], references: [id])
  createdBy User            @relation(fields: [createdById], references: [id])
  movements StockMovement[]

  @@index([warehouseId])
  @@index([status])
  @@index([createdById])
  @@map("physical_inventory_sessions")
}

enum WebhookEventType {
  stock_low       @map("stock.low")
  stock_out       @map("stock.out")
  movement_created @map("movement.created")
  batch_expiring   @map("batch.expiring")
  inventory_reconciled @map("inventory.reconciled")
  purchase_order_received @map("purchase_order.received")
}

model WebhookSubscription {
  id              String             @id @default(uuid()) @db.Uuid
  url             String
  encryptedSecret String             @map("encrypted_secret")
  events          WebhookEventType[]
  isActive        Boolean            @default(true) @map("is_active")
  createdById     String             @map("created_by_id") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  createdBy       User               @relation(fields: [createdById], references: [id])
  deliveries      WebhookDelivery[]

  @@index([isActive])
  @@index([createdById])
  @@map("webhook_subscriptions")
}

model WebhookDelivery {
  id             String              @id @default(uuid()) @db.Uuid
  subscriptionId String              @map("subscription_id") @db.Uuid
  event          WebhookEventType
  statusCode     Int?                @map("status_code")
  responseBody   String?             @map("response_body") @db.VarChar(500)
  duration       Int
  attemptNumber  Int                 @map("attempt_number")
  deliveredAt    DateTime            @default(now()) @map("delivered_at")

  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([event])
  @@map("webhook_deliveries")
}

model Supplier {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  taxId     String   @unique @map("tax_id")
  email     String?
  phone     String?
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}
